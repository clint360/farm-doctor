# ─────────────────────────────────────
# Farm Doctor Website Environment Variables
# ─────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────

# ─── Backend API URL ────────────────
# Points to the Fastify backend for subscription, Retell calls, etc.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Retell AI (optional) ──────────
# Only needed if you want to override the backend URL for calls
# NEXT_PUBLIC_RETELL_BACKEND_URL=http://localhost:3001

# ─── Contact Details ──────────────
# All contact info used across the website (hero, channels, footer, etc.)
NEXT_PUBLIC_WHATSAPP_NUMBER=237693477577
NEXT_PUBLIC_WHATSAPP_DISPLAY=+237 6 93 47 75 77
NEXT_PUBLIC_CALL_NUMBER=237680612360
NEXT_PUBLIC_CALL_DISPLAY=+237 6 80 61 23 60
NEXT_PUBLIC_COMPANY_PHONE=237693477577
NEXT_PUBLIC_COMPANY_DISPLAY=+237 6 93 47 75 77
NEXT_PUBLIC_TELEGRAM_BOT=Farm_doctor_bot
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/share/1AR6vKAdz6/?mibextid=wwXIfr
